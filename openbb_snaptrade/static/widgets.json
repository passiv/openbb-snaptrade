          },
          {
            "label": "Sell",
            "value": "SELL"
          },
          {
            "label": "Dividend",
            "value": "DIVIDEND"
          },
          {
            "label": "Interest",
            "value": "INTEREST"
          },
          {
            "label": "Deposit",
            "value": "DEPOSIT"
          },
          {
            "label": "Withdrawal",
            "value": "WITHDRAWAL"
          },
          {
            "label": "Fee",
            "value": "FEE"
          },
          {
            "label": "Transfer",
            "value": "TRANSFER"
          },
          {
            "label": "Stock Split",
            "value": "STOCK_DIVIDEND"
          },
          {
            "label": "Option Expiration",
            "value": "OPTIONEXPIRATION"
          },
          {
            "label": "Option Assignment",
            "value": "OPTIONASSIGNMENT"
          },
          {
            "label": "Option Exercise",
            "value": "OPTIONEXERCISE"
          }
        ]
      }
    ],
    "data": {
      "table": {
        "showAll": true,
        "enableCharts": true,
        "enableAdvanced": true,
        "columnsDefs": [
          {
            "field": "trade_date",
            "headerName": "Trade Date",
            "cellDataType": "dateString",
            "width": 130,
            "pinned": "left"
          },
          {
            "field": "settlement_date",
            "headerName": "Settled",
            "cellDataType": "dateString",
            "width": 130
          },
          {
            "field": "account_name",
            "headerName": "Account",
            "cellDataType": "text",
            "width": 160
          },
          {
            "field": "type",
            "headerName": "Type",
            "cellDataType": "text",
            "width": 130
          },
          {
            "field": "symbol",
            "headerName": "Symbol",
            "cellDataType": "text",
            "width": 110
          },
          {
            "field": "description",
            "headerName": "Description",
            "cellDataType": "text",
            "width": 320
          },
          {
            "field": "units",
            "headerName": "Units",
            "cellDataType": "number",
            "decimalPlaces": 4,
            "width": 110
          },
          {
            "field": "price",
            "headerName": "Price",
            "cellDataType": "number",
            "decimalPlaces": 4,
            "width": 110
          },
          {
            "field": "amount",
            "headerName": "Amount",
            "cellDataType": "number",
            "decimalPlaces": 2,
            "width": 130,
            "renderFn": "greenRed"
          },
          {
            "field": "fee",
            "headerName": "Fee",
