  "snaptrade_orders": {
    "name": "Orders",
    "description": "Open and recent orders across connected brokerage accounts.",
    "endpoint": "snaptrade/orders",
    "type": "table",
    "category": "Brokerage",
    "subCategory": "Trading",
    "gridData": {
      "w": 40,
      "h": 18
    },
    "source": ["SnapTrade"],
    "params": [
      {
        "type": "endpoint",
        "paramName": "accountId",
        "label": "Account",
        "value": "__all__",
        "show": true,
        "description": "Filter orders by account. Defaults to all accounts.",
        "optionsEndpoint": "snaptrade/account-options"
      },
      {
        "type": "text",
        "paramName": "state",
        "label": "State",
        "value": "all",
        "show": true,
        "description": "Order state filter.",
        "options": [
          {
            "label": "All",
            "value": "all"
          },
          {
            "label": "Open",
            "value": "open"
          },
          {
            "label": "Executed",
            "value": "executed"
          },
          {
            "label": "Canceled",
            "value": "canceled"
          },
          {
            "label": "Recent (last fills)",
            "value": "recent"
          }
        ]
      },
      {
        "type": "number",
        "paramName": "days",
        "label": "Days back",
        "value": 30,
        "show": true,
        "description": "How many days of history to include (ignored when state=recent)."
      }
    ],
    "data": {
      "table": {
        "showAll": true,
        "enableCharts": true,
        "enableAdvanced": true,
        "columnsDefs": [
          {
            "field": "time_placed",
            "headerName": "Placed",
            "cellDataType": "dateString",
            "width": 170,
            "pinned": "left"
          },
          {
            "field": "account_name",
            "headerName": "Account",
            "cellDataType": "text",
            "width": 160
          },
          {
            "field": "symbol",
            "headerName": "Symbol",
            "cellDataType": "text",
            "width": 110
          },
          {
            "field": "description",
            "headerName": "Description",
            "cellDataType": "text",
            "width": 260
          },
          {
            "field": "action",
            "headerName": "Action",
            "cellDataType": "text",
            "width": 100
          },
          {
            "field": "order_type",
            "headerName": "Type",
            "cellDataType": "text",
            "width": 110
          },
          {
            "field": "status",
            "headerName": "Status",
            "cellDataType": "text",
            "width": 120,
            "renderFn": "columnColor",
            "renderFnParams": {
              "colorRules": [
                {
                  "condition": "contains",
                  "value": "EXECUTED",
                  "color": "#16a34a",
                  "fill": true
                },
                {
                  "condition": "contains",
                  "value": "FILLED",
                  "color": "#16a34a",
                  "fill": true
                },
                {
                  "condition": "contains",
                  "value": "CANCEL",
                  "color": "#dc2626",
                  "fill": true
                },
                {
                  "condition": "contains",
                  "value": "REJECT",
                  "color": "#dc2626",
                  "fill": true
                },
                {
                  "condition": "contains",
                  "value": "OPEN",
                  "color": "#2563eb",
                  "fill": true
                },
                {
                  "condition": "contains",
                  "value": "PENDING",
                  "color": "#ca8a04",
                  "fill": true
                }
              ]
            }
          },
          {
            "field": "total_quantity",
            "headerName": "Qty",
            "cellDataType": "number",
            "decimalPlaces": 4,
            "width": 110
          },
          {
            "field": "filled_quantity",
            "headerName": "Filled",
            "cellDataType": "number",
            "decimalPlaces": 4,
            "width": 110
          },
          {
            "field": "execution_price",
            "headerName": "Avg Px",
            "cellDataType": "number",
            "decimalPlaces": 4,
            "width": 110
          },
          {
            "field": "limit_price",
            "headerName": "Limit",
            "cellDataType": "number",
            "decimalPlaces": 4,
            "width": 110
          },
          {
            "field": "stop_price",
            "headerName": "Stop",
            "cellDataType": "number",
            "decimalPlaces": 4,
            "width": 110
          },
          {
            "field": "time_in_force",
            "headerName": "TIF",
            "cellDataType": "text",
            "width": 90
          },
          {
            "field": "time_executed",
            "headerName": "Executed",
            "cellDataType": "dateString",
            "width": 170
          },
          {
            "field": "brokerage_order_id",
            "headerName": "Order ID",
            "cellDataType": "text",
            "width": 220,
            "hide": true
          }
        ]
      }
    }
  },
  "snaptrade_activities": {
    "name": "Activities",
    "description": "Brokerage activity feed: trades, dividends, deposits, fees, and corporate actions.",
    "endpoint": "snaptrade/activities",
